APP_ENV=local
DATABASE_PATH=visitors.db
DATABASE_TIMEOUT_SECONDS=5
SQLITE_BUSY_TIMEOUT_MS=5000

# 推送通道: serverchan | pushplus | noop
NOTIFIER_PROVIDER=serverchan

# Server酱 (sct.ftqq.com) SendKey —— 主通道
SERVERCHAN_SENDKEY=
# 若用 Server酱³，把基础地址改成控制台给的地址；Turbo 版用默认即可
SERVERCHAN_API_BASE=https://sctapi.ftqq.com

# pushplus (pushplus.plus) token —— 备用通道
PUSHPLUS_TOKEN=

# 推送超时（秒），防止拖垮 25 秒预算
NOTIFY_TIMEOUT_SECONDS=8

# 门卫查询 Agent 的 LLM（OpenAI 兼容接口）。留空则自动降级为关键词规则。
# 国内推荐 DeepSeek：到 https://platform.deepseek.com 申请 key
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=12

# 公司名标准化默认 fast 模式，不调 LLM，保证登记低延迟。
# 需要实验“候选召回 + LLM 受限重排”时再打开。
COMPANY_RESOLVE_USE_LLM=false
COMPANY_RESOLVE_LLM_TIMEOUT_SECONDS=1.8

# 手机端 Web Call 入口。Public Key 可用于浏览器端；Assistant ID 来自 Vapi Assistant 页面。
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=
